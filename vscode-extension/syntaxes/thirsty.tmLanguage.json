{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Thirsty-lang",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.thirsty",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.thirsty",
          "match": "\\b(thirsty|hydrated|refill|return|import|export|await|cascade)\\b"
        },
        {
          "name": "keyword.declaration.thirsty",
          "match": "\\b(drink|glass|fountain|reservoir)\\b"
        },
        {
          "name": "keyword.other.thirsty",
          "match": "\\b(pour|sip)\\b"
        },
        {
          "name": "keyword.security.thirsty",
          "match": "\\b(shield|sanitize|armor|morph|detect|defend)\\b"
        },
        {
          "name": "constant.language.thirsty",
          "match": "\\b(true|false|this)\\b"
        },
        {
          "name": "support.class.thirsty",
          "match": "\\b(Math|String|File|Http)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.thirsty",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.thirsty",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.thirsty",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.thirsty",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.thirsty",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.thirsty",
          "match": "=|\\+|\\-|\\*|/|>|<|==|!=|>=|<="
        }
      ]
    }
  },
  "scopeName": "source.thirsty"
}
