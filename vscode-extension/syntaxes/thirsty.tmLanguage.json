{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Thirsty-lang",
  "scopeName": "source.thirsty",
  "fileTypes": [
    "thirsty",
    "thirstofgods",
    "tog",
    "tarl",
    "shadow",
    "tscg",
    "tscgb"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#class-definition"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#async-function-definition"
    },
    {
      "include": "#keywords-control"
    },
    {
      "include": "#keywords-declaration"
    },
    {
      "include": "#keywords-io"
    },
    {
      "include": "#keywords-async"
    },
    {
      "include": "#keywords-error"
    },
    {
      "include": "#keywords-module"
    },
    {
      "include": "#keywords-oop"
    },
    {
      "include": "#keywords-builtin"
    },
    {
      "include": "#keywords-tscg"
    },
    {
      "include": "#keywords-tarl"
    },
    {
      "include": "#keywords-shadow"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#arrow-operator"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.thirsty",
          "match": "//.*$"
        },
        {
          "name": "comment.block.thirsty",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "class-definition": {
      "patterns": [
        {
          "match": "\\b(fountain)\\s+(\\w+)",
          "captures": {
            "1": {
              "name": "keyword.declaration.class.thirsty"
            },
            "2": {
              "name": "entity.name.type.class.thirsty"
            }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(glass)\\s+(\\w+)\\s*\\(",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.thirsty"
            },
            "2": {
              "name": "entity.name.function.thirsty"
            }
          }
        }
      ]
    },
    "async-function-definition": {
      "patterns": [
        {
          "match": "\\b(cascade)\\s+(glass)\\s+(\\w+)\\s*\\(",
          "captures": {
            "1": {
              "name": "keyword.control.async.thirsty"
            },
            "2": {
              "name": "keyword.declaration.function.thirsty"
            },
            "3": {
              "name": "entity.name.function.thirsty"
            }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b(\\w+)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.call.thirsty"
            }
          }
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.conditional.thirsty",
          "match": "\\b(thirsty|hydrated|parched|quenched)\\b"
        },
        {
          "name": "keyword.control.loop.thirsty",
          "match": "\\b(refill|endrefill)\\b"
        },
        {
          "name": "keyword.control.flow.thirsty",
          "match": "\\b(return|break|continue)\\b"
        }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        {
          "name": "keyword.declaration.variable.thirsty",
          "match": "\\b(drink)\\b"
        },
        {
          "name": "keyword.declaration.function.thirsty",
          "match": "\\b(glass|endglass)\\b"
        },
        {
          "name": "keyword.declaration.class.thirsty",
          "match": "\\b(fountain|endfountain)\\b"
        }
      ]
    },
    "keywords-io": {
      "patterns": [
        {
          "name": "keyword.other.output.thirsty",
          "match": "\\b(pour)\\b"
        },
        {
          "name": "keyword.other.input.thirsty",
          "match": "\\b(sip)\\b"
        }
      ]
    },
    "keywords-async": {
      "patterns": [
        {
          "name": "keyword.control.async.thirsty",
          "match": "\\b(cascade|await)\\b"
        }
      ]
    },
    "keywords-error": {
      "patterns": [
        {
          "name": "keyword.control.trycatch.thirsty",
          "match": "\\b(spillage|cleanup|endcleanup)\\b"
        }
      ]
    },
    "keywords-module": {
      "patterns": [
        {
          "name": "keyword.control.import.thirsty",
          "match": "\\b(import|export|sacred)\\b"
        }
      ]
    },
    "keywords-oop": {
      "patterns": [
        {
          "name": "keyword.operator.new.thirsty",
          "match": "\\b(new)\\b"
        },
        {
          "name": "variable.language.this.thirsty",
          "match": "\\b(this)\\b"
        }
      ]
    },
    "keywords-builtin": {
      "patterns": [
        {
          "name": "support.type.builtin.thirsty",
          "match": "\\b(ocean|stream|reservoir|bottle)\\b"
        }
      ]
    },
    "keywords-tscg": {
      "comment": "TSCG / TSCG-B Constitutional Grammar keywords",
      "patterns": [
        {
          "name": "keyword.other.tscg.thirsty",
          "match": "\\b(ING|COG|D_NT|SHD|INV|CAP|QRM_LINEAR|COM|ANC|LED|T_BLOB)\\b"
        },
        {
          "name": "keyword.other.tscg.directive.thirsty",
          "match": "\\b(ENCODE|DECODE|PARITY|VALIDATE|BIJECTIVITY)\\b"
        }
      ]
    },
    "keywords-tarl": {
      "comment": "T.A.R.L. (Thirstys Active Resistance Language) keywords",
      "patterns": [
        {
          "name": "keyword.other.tarl.thirsty",
          "match": "\\b(policy|capability|workflow|orchestrate|enforce|provision|constraint|deterministic|provenance|capsule|audit|override|governance|compliance|runtime|execute|verify|replay)\\b"
        }
      ]
    },
    "keywords-shadow": {
      "comment": "Shadow Thirst (Thirsty's Shadow) keywords",
      "patterns": [
        {
          "name": "keyword.other.shadow.thirsty",
          "match": "\\b(shadow|plane|primary|secondary|PUSH|POP|RETURN|CALL|GUARD|HALT|LOAD|STORE|containment|bytecode|opcode)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.thirsty",
          "match": "\\b(true|false|null|undefined|none)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.thirsty",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.thirsty",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.thirsty",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.thirsty",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.thirsty",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.thirsty",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.thirsty",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.thirsty",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.assignment.thirsty",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.thirsty",
          "match": "\\+|\\-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.thirsty",
          "match": "\\b(AND|OR|NOT)\\b"
        }
      ]
    },
    "arrow-operator": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.thirsty",
          "match": "->"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "\\b(drink)\\s+(\\w+)",
          "captures": {
            "1": {
              "name": "keyword.declaration.variable.thirsty"
            },
            "2": {
              "name": "variable.other.thirsty"
            }
          }
        }
      ]
    }
  }
}