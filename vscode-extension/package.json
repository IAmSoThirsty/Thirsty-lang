{
  "name": "Thirsty-Lang",
  "displayName": "Thirsty-Lang — The Hydration Language Family",
  "description": "Language support for the Thirsty language family: Thirsty-Lang, Thirst of Gods, T.A.R.L., and Thirsty's Shadow",
  "version": "1.0.0",
  "publisher": "IAmSoThirsty",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IAmSoThirsty/Thirsty-Lang"
  },
  "homepage": "https://github.com/IAmSoThirsty/Thirsty-Lang",
  "bugs": {
    "url": "https://github.com/IAmSoThirsty/Thirsty-Lang/issues"
  },
  "galleryBanner": {
    "color": "#0A1628",
    "theme": "dark"
  },
  "keywords": [
    "thirsty",
    "Thirsty-Lang",
    "thirst-of-gods",
    "tarl",
    "thirstys-shadow",
    "programming-language",
    "water",
    "hydration",
    "defensive-programming",
    "security"
  ],
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "thirsty",
        "aliases": [
          "Thirsty",
          "Thirsty-Lang",
          "Thirst of Gods",
          "T.A.R.L.",
          "Thirsty's Shadow"
        ],
        "extensions": [
          ".thirsty",
          ".tog",
          ".tarl",
          ".shadow"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "thirsty",
        "scopeName": "source.thirsty",
        "path": "./syntaxes/thirsty.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "thirsty",
        "path": "./snippets/thirsty.json"
      }
    ]
  }
}